# Staging Environment Configuration Template
# Copy to .env.staging locally and provide real secrets outside version control.

# Application
APP_NAME=AST Tools
DEBUG=False
ENVIRONMENT=staging

# Database
DATABASE_URL=postgresql+psycopg://<username>:<password>@<host>:<port>/<database>
DB_HOST=<host>
DB_PORT=5432
DB_NAME=<database>
DB_USER=<username>
DB_PASSWORD=<password>

# Redis Cache
REDIS_URL=redis://<host>:7071/0

# JWT Configuration
JWT_SECRET=<random_32_byte_hex>
JWT_ALGORITHM=HS256
JWT_ALG=HS256
JWT_TTL=86400
JWT_REFRESH_TTL=864000
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Hashing (Argon2)
ARGON2_TIME_COST=2
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# AST Tools Configuration
ASTPARSER_TEST_BASE=http://<host>:7070
ASTPARSER_API_KEY=<api_key>
ASTPARSER_ADMIN_KEY=<admin_key>
UPLOAD_PERSIST=1
UPLOAD_TTL_SECONDS=3600
UPLOAD_MAX_SIZE_MB=50

# External DUT API
DUT_API_BASE_URL=http://<host>:9001
DUT_API_TIMEOUT=120

# iPLAS API URLs and Tokens
IPLAS_API_PTB_BASE_URL=http://<ptb-host>
IPLAS_API_PSZ_BASE_URL=http://<psz-host>
IPLAS_API_PXD_BASE_URL=http://<pxd-host>
IPLAS_API_PVN_BASE_URL=http://<pvn-host>
IPLAS_API_PTY_BASE_URL=http://<pty-host>
IPLAS_V1_API_VERSION=/api/v1
IPLAS_V2_API_VERSION=/api/v2
IPLAS_API_PORT=32678
IPLAS_API_TIMEOUT=180
IPLAS_API_TOKEN_PTB=<token>
IPLAS_API_TOKEN_PSZ=<token>
IPLAS_API_TOKEN_PXD=<token>
IPLAS_API_TOKEN_PVN=<token>
IPLAS_API_TOKEN_PTY=<token>

# iPLAS API Configuration
IPLAS_DEVICE_DENSITY_THRESHOLD=10
IPLAS_DEVICE_BATCH_SIZE=5
IPLAS_MAX_PARALLEL_REQUESTS=3

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# Logging
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Server Configuration
HOST=0.0.0.0
PORT=7070
WORKERS=4

# SFISTSP Web Service Configuration
SFISTSP_API_BASE_URL=http://<sfistsp-host>/
SFISTSP_API_SERVER_ADDRESS=http://<sfistsp-host>/SFISWebService/SFISTSPWebService.asmx
SFIS_DEFAULT_PROGRAM_ID=<program_id>
SFIS_DEFAULT_PROGRAM_PASSWORD=<program_password>
SFISTSP_API_TIMEOUT=120